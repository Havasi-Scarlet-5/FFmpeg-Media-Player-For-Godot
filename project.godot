; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="FFmpeg Media Player"
config/description="FFmpeg Media Player For Godot Engine Using FFmpeg.AutoGen C#."
config/version="1.5.0"
config/tags=PackedStringArray("extension")
run/main_scene="uid://d2c5w5moq4ktk"
config/features=PackedStringArray("4.7", "C#", "Forward Plus")
run/flush_stdout_on_print=true
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/image="uid://br3x77gnlokfr"
config/icon="uid://ddiym4myxm6ge"

[autoload]

FFmpegAutoLoad="*uid://bwxfma4sy866m"

[debug]

file_logging/enable_file_logging=true

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

[dotnet]

project/assembly_name="FFmpeg Media Player"

[editor_plugins]

enabled=PackedStringArray("res://addons/FFmpegMediaPlayer/FFmpegGodot/plugin.cfg")

[network]

limits/debugger/max_chars_per_second=2147483647
limits/debugger/max_queued_messages=2147483647
limits/debugger/max_errors_per_second=2147483647
limits/debugger/max_warnings_per_second=2147483647

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
